---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'RefineFlow Works', description = 'アプリ・システムの企画・開発・支援' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="ja" data-theme="dark" data-lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400&family=Noto+Sans+JP:wght@300;400&family=Noto+Serif+JP:wght@700&family=Space+Grotesk:wght@700&display=swap"
      rel="stylesheet"
    />
    <!-- Prevent flash: apply saved theme and lang before first paint -->
    <script is:inline>
      (function () {
        const t = localStorage.getItem('theme') || 'dark';
        const l = localStorage.getItem('lang')  || 'ja';
        document.documentElement.setAttribute('data-theme', t);
        document.documentElement.setAttribute('data-lang', l);
        document.documentElement.lang = l === 'ja' ? 'ja' : 'en';
      })();
    </script>
  </head>
  <body>
    <slot />

    <script>
      // ── Scroll reveal ──
      const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const delay = parseFloat((entry.target as HTMLElement).dataset.delay || '0');
              setTimeout(() => entry.target.classList.add('visible'), delay * 1000);
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      revealEls.forEach((el) => io.observe(el));

      // ── Theme toggle ──
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const curr = document.documentElement.getAttribute('data-theme');
        const next = curr === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });

      // ── Language toggle ──
      function applyLang(lang: string) {
        document.documentElement.setAttribute('data-lang', lang);
        document.documentElement.lang = lang === 'ja' ? 'ja' : 'en';
        localStorage.setItem('lang', lang);
        // Update elements with data-ja / data-en attributes (hero title spans)
        document.querySelectorAll<HTMLElement>('[data-ja][data-en]').forEach(el => {
          el.textContent = lang === 'en'
            ? el.getAttribute('data-en') ?? ''
            : el.getAttribute('data-ja') ?? '';
        });
      }

      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        const curr = document.documentElement.getAttribute('data-lang') || 'ja';
        applyLang(curr === 'ja' ? 'en' : 'ja');
      });

      // Apply on load (handles case where lang='en' was saved)
      const savedLang = document.documentElement.getAttribute('data-lang') || 'ja';
      if (savedLang === 'en') applyLang('en');
    </script>
  </body>
</html>
