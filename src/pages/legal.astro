---
import Layout from '../layouts/Layout.astro';
---
<Layout title="特定商取引法に基づく表記 | Your Company">
<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 3rem; height: 56px;
    display: flex; align-items: center; justify-content: space-between;
    background: var(--bg); border-bottom: 1px solid var(--border);
  }
  .nav-logo { font-family: var(--font-display); font-size: 14px; font-weight: 700; }
  .nav-logo span { color: var(--accent); }
  .nav-back {
    font-family: var(--font-display); font-size: 12px; font-weight: 400;
    letter-spacing: 0.08em; color: var(--fg-2); text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-back:hover { color: var(--fg); }

  main { max-width: 900px; margin: 0 auto; padding: 112px 3rem 96px; }

  .section-head {
    display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 4rem;
  }
  .section-num { font-family: var(--font-display); font-size: 11px; color: var(--fg-3); }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 48px); font-weight: 800; letter-spacing: -0.03em; line-height: 1;
  }

  .legal-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .legal-table tr { border-bottom: 1px solid var(--border); }
  .legal-table tr:first-child { border-top: 1px solid var(--border); }
  .legal-table th {
    font-family: var(--font-display); font-size: 10px;
    letter-spacing: 0.1em; color: var(--fg-3); text-transform: uppercase;
    font-weight: 400; text-align: left; padding: 1.25rem 1.5rem 1.25rem 0;
    width: 180px; vertical-align: top;
  }
  .legal-table td { padding: 1.25rem 0; color: var(--fg-2); line-height: 1.8; }
  .legal-table a { color: var(--accent); border-bottom: 1px solid transparent; transition: border-color 0.2s; }
  .legal-table a:hover { border-color: var(--accent); }

  footer {
    max-width: 900px; margin: 0 auto; padding: 2rem 3rem;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-logo { font-family: var(--font-display); font-size: 13px; font-weight: 700; }
  .footer-logo span { color: var(--accent); }
  .footer-copy { font-size: 12px; color: var(--fg-3); }

  @media (max-width: 700px) {
    nav { padding: 0 1.5rem; }
    main { padding: 88px 1.5rem 60px; }
    .legal-table th { width: 120px; }
    footer { flex-direction: column; gap: 0.5rem; text-align: center; padding: 1.5rem; }
  }
</style>

<nav>
  <span class="nav-logo">Your<span>/</span>Company</span>
  <a class="nav-back" href="/">← Back</a>
</nav>

<main>
  <div class="section-head reveal">
    <span class="section-num">—</span>
    <h1 class="section-title">LEGAL</h1>
  </div>
  <table class="legal-table">
    <tbody>
      <tr class="reveal"><th>販売事業者</th><td>Your Company</td></tr>
      <tr class="reveal"><th>代表者</th><td>請求があった場合、遅滞なく開示いたします</td></tr>
      <tr class="reveal"><th>所在地</th><td>請求があった場合、遅滞なく開示いたします</td></tr>
      <tr class="reveal"><th>電話番号</th><td>請求があった場合、遅滞なく開示いたします</td></tr>
      <tr class="reveal"><th>メールアドレス</th><td><a href="mailto:your@email.com">your@email.com</a></td></tr>
      <tr class="reveal"><th>販売価格</th><td>各アプリ・サービスのページに記載</td></tr>
      <tr class="reveal"><th>支払方法</th><td>各プラットフォーム（App Store / Google Play / Steam）の決済方法に準拠</td></tr>
      <tr class="reveal"><th>商品の引渡時期</th><td>購入手続き完了後、ただちにダウンロード可能</td></tr>
      <tr class="reveal"><th>返品・キャンセル</th><td>各プラットフォームの規約に準拠</td></tr>
      <tr class="reveal"><th>動作環境</th><td>各アプリ・サービスのページに記載</td></tr>
    </tbody>
  </table>
</main>

<footer>
  <span class="footer-logo">Your<span>/</span>Company</span>
  <span class="footer-copy">© 2025 Your Company</span>
</footer>
</Layout>
