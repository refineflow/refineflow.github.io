---
import Layout from '../layouts/Layout.astro';
---
<Layout>
<style>
  /* ── Nav ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 3rem;
    height: 56px;
    display: flex; align-items: center; justify-content: space-between;
    background: var(--bg);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }
  nav.scrolled { border-color: var(--border); }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 14px; font-weight: 700; letter-spacing: 0.01em;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-family: var(--font-display);
    font-size: 12px; font-weight: 400; letter-spacing: 0.08em;
    color: var(--fg-2); text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--fg); }

  /* ── Hero ── */
  #hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center;
    padding: 80px 2rem 4rem;
    position: relative;
  }
  .hero-eyebrow {
    font-family: var(--font-display);
    font-size: 11px; letter-spacing: 0.2em; color: var(--fg-3);
    text-transform: uppercase; margin-bottom: 2rem;
    animation: fadeUp 0.8s 0.1s both;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 10vw, 120px);
    font-weight: 800; line-height: 0.9;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    animation: fadeUp 0.8s 0.2s both;
  }
  .hero-title .accent { color: var(--accent); }
  .hero-sub {
    font-size: 16px; color: var(--fg-2); line-height: 1.9;
    animation: fadeUp 0.8s 0.35s both;
    margin-bottom: 3rem;
  }
  .hero-badges {
    display: flex; gap: 1.5rem; justify-content: center;
    animation: fadeUp 0.8s 0.5s both;
  }
  .badge {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }
  .badge-label {
    font-family: var(--font-display);
    font-size: 9px; letter-spacing: 0.15em; color: var(--fg-3); text-transform: uppercase;
  }
  .badge-value {
    font-family: var(--font-display);
    font-size: 12px; font-weight: 700; letter-spacing: 0.05em;
  }
  .badge-value.online { color: #2eb87a; }
  .hero-scroll {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: 10px; letter-spacing: 0.15em; color: var(--fg-3); text-transform: uppercase;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    animation: fadeUp 0.8s 0.7s both;
  }
  .scroll-arrow {
    width: 1px; height: 40px; background: var(--fg-3);
    animation: scrollPulse 1.8s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Sections ── */
  .section-wrap {
    max-width: 900px; margin: 0 auto; padding: 96px 3rem;
    border-top: 1px solid var(--border);
  }
  .section-head {
    display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 4rem;
  }
  .section-num {
    font-family: var(--font-display);
    font-size: 11px; color: var(--fg-3); letter-spacing: 0.1em;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800; letter-spacing: -0.03em; line-height: 1;
  }

  /* ── About ── */
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;
  }
  .about-text { color: var(--fg-2); line-height: 2; }
  .about-text p + p { margin-top: 1rem; }
  .about-meta { display: flex; flex-direction: column; gap: 1rem; }
  .meta-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
  }
  .meta-card-label {
    font-family: var(--font-display);
    font-size: 10px; letter-spacing: 0.1em; color: var(--fg-3);
    text-transform: uppercase; margin-bottom: 0.4rem;
  }
  .meta-card-value { font-size: 14px; font-weight: 400; }

  /* ── Services ── */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .service-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    transition: transform 0.2s, border-color 0.2s;
  }
  .service-card:hover { transform: translateY(-4px); border-color: #bbb; }
  .service-card-num {
    font-family: var(--font-display);
    font-size: 10px; letter-spacing: 0.1em; color: var(--fg-3);
    margin-bottom: 1rem;
  }
  .service-card-name {
    font-family: var(--font-display);
    font-size: 17px; font-weight: 700; margin-bottom: 0.75rem; letter-spacing: -0.01em;
  }
  .service-card-desc { font-size: 13px; color: var(--fg-2); line-height: 1.8; }

  /* ── Contact ── */
  .contact-list { list-style: none; }
  .contact-item {
    display: grid; grid-template-columns: 100px 1fr;
    gap: 1rem; padding: 1.25rem 0;
    border-bottom: 1px solid var(--border); font-size: 14px; align-items: baseline;
  }
  .contact-item:first-child { border-top: 1px solid var(--border); }
  .contact-key {
    font-family: var(--font-display);
    font-size: 10px; letter-spacing: 0.12em; color: var(--fg-3); text-transform: uppercase;
  }
  .contact-val a {
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .contact-val a:hover { border-color: var(--accent); }

  /* ── Footer ── */
  footer {
    max-width: 900px; margin: 0 auto;
    padding: 2rem 3rem;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-logo {
    font-family: var(--font-display); font-size: 13px; font-weight: 700;
  }
  .footer-logo span { color: var(--accent); }
  .footer-copy { font-size: 12px; color: var(--fg-3); }
  .footer-legal a { font-size: 12px; color: var(--fg-3); transition: color 0.2s; }
  .footer-legal a:hover { color: var(--fg); }

  @media (max-width: 700px) {
    nav { padding: 0 1.5rem; }
    .nav-links { gap: 1.2rem; }
    .section-wrap { padding: 64px 1.5rem; }
    .about-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr; }
    .contact-item { grid-template-columns: 1fr; gap: 0.2rem; }
    footer { flex-direction: column; gap: 0.5rem; text-align: center; padding: 1.5rem; }
  }
</style>

<nav id="navbar">
  <span class="nav-logo">Your<span>/</span>Company</span>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<main>
  <!-- Hero -->
  <section id="hero">
    <p class="hero-eyebrow">App & System Studio</p>
    <h1 class="hero-title">YOUR<br/><span class="accent">COMPANY</span></h1>
    <p class="hero-sub">アプリ・システムの<br/>マネジメント・開発・支援</p>
    <div class="hero-badges">
      <div class="badge">
        <span class="badge-label">Status</span>
        <span class="badge-value online">OPEN</span>
      </div>
      <div class="badge">
        <span class="badge-label">Base</span>
        <span class="badge-value">JP</span>
      </div>
      <div class="badge">
        <span class="badge-label">Type</span>
        <span class="badge-value">Solo</span>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- About -->
  <div class="section-wrap">
    <div class="section-head reveal">
      <span class="section-num">01</span>
      <h2 class="section-title">ABOUT</h2>
    </div>
    <div class="about-grid">
      <div class="about-text reveal">
        <p>Your Company は、アプリ・システム開発を専門とする個人事業です。</p>
        <p>企画・設計から開発・運用まで、プロダクトのライフサイクル全体を一貫してサポートします。小さなチームや個人でも動かせる、シンプルで堅牢な仕組みづくりを大切にしています。</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="meta-card reveal">
          <p class="meta-card-label">事業者名</p>
          <p class="meta-card-value">Your Company</p>
        </div>
        <div class="meta-card reveal">
          <p class="meta-card-label">事業形態</p>
          <p class="meta-card-value">個人事業主</p>
        </div>
        <div class="meta-card reveal">
          <p class="meta-card-label">事業内容</p>
          <p class="meta-card-value">アプリ・システムの企画・開発・運営</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Services -->
  <div class="section-wrap">
    <div class="section-head reveal">
      <span class="section-num">02</span>
      <h2 class="section-title">SERVICES</h2>
    </div>
    <div class="services-grid">
      <div class="service-card reveal">
        <p class="service-card-num">01</p>
        <p class="service-card-name">マネジメント</p>
        <p class="service-card-desc">プロジェクトの計画・進行・品質管理。開発チームとの橋渡し役として、確実な納品をサポートします。</p>
      </div>
      <div class="service-card reveal">
        <p class="service-card-num">02</p>
        <p class="service-card-name">開発</p>
        <p class="service-card-desc">モバイルアプリ・Webシステムの設計・実装。要件定義から本番リリースまで対応します。</p>
      </div>
      <div class="service-card reveal">
        <p class="service-card-num">03</p>
        <p class="service-card-name">支援</p>
        <p class="service-card-desc">既存システムの改善・保守・技術相談。課題整理から実行まで、柔軟にご支援します。</p>
      </div>
    </div>
  </div>

  <!-- Contact -->
  <div class="section-wrap">
    <div class="section-head reveal">
      <span class="section-num">03</span>
      <h2 class="section-title">CONTACT</h2>
    </div>
    <ul class="contact-list">
      <li class="contact-item reveal">
        <span class="contact-key">Email</span>
        <span class="contact-val"><a href="mailto:your@email.com">your@email.com</a></span>
      </li>
      <li class="contact-item reveal">
        <span class="contact-key">Web</span>
        <span class="contact-val"><a href="https://yourwebsite.com" target="_blank" rel="noopener">yourwebsite.com</a></span>
      </li>
      <li class="contact-item reveal">
        <span class="contact-key">Location</span>
        <span class="contact-val"><a href="/legal">特定商取引法に基づく表記に記載 →</a></span>
      </li>
    </ul>
  </div>
</main>

<footer>
  <span class="footer-logo">Your<span>/</span>Company</span>
  <span class="footer-copy">© 2025 Your Company</span>
  <span class="footer-legal"><a href="/legal">特定商取引法</a></span>
</footer>

<script>
  const nav = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 20);
  });
</script>
</Layout>
