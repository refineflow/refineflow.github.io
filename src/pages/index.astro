---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RefineFlow Works — 想いを、動くものに。" description="アプリ・システムの企画・開発・支援を行っています。">
<style>
  /* ━━ Nav ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  #nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: 60px; padding: 0 3rem;
    display: flex; align-items: center; justify-content: space-between;
    background: transparent; border-bottom: 1px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease, backdrop-filter 0.4s ease;
  }
  #nav.scrolled {
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(18px) saturate(180%);
    -webkit-backdrop-filter: blur(18px) saturate(180%);
    border-color: var(--border);
  }

  /* ── Logo ── */
  .nav-logo {
    font-family: var(--font-mono); font-size: 15px; letter-spacing: -0.01em;
    display: flex; align-items: center; gap: 9px;
  }
  .nav-logo-icon { flex-shrink: 0; border-radius: 5px; }
  .nav-logo-text {
    font-family: 'Space Grotesk', sans-serif; font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg,
      #3b82f6 0%, #60a5fa 18%, #93c5fd 35%, #bfdbfe 50%,
      #93c5fd 65%, #60a5fa 82%, #3b82f6 100%);
    background-size: 280% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: logoFlow 7s ease-in-out infinite;
  }

  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--fg-2); transition: color 0.2s ease;
  }
  .nav-links a:hover { color: var(--fg); }
  .nav-right { display: flex; align-items: center; gap: 1rem; }
  @media (max-width: 640px) {
    #nav { padding: 0 1.5rem; }
    .nav-links { display: none; }
  }

  /* ━━ Hero ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  #hero {
    position: relative; min-height: 100svh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 100px 2rem 5rem; overflow: hidden;
  }

  /* Subtle grid */
  #hero::before {
    content: ''; position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(59, 130, 246, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59, 130, 246, 0.045) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 80%);
    pointer-events: none;
  }
  [data-theme="light"] #hero::before {
    background-image:
      linear-gradient(rgba(37, 99, 235, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37, 99, 235, 0.055) 1px, transparent 1px);
  }

  /* ── Organic blobs — slow flame, moderate intensity ── */
  .hero-blob { position: absolute; pointer-events: none; will-change: transform; }
  .hero-blob-1 {
    width: 660px; height: 560px;
    background: radial-gradient(ellipse at 50% 44%,
      rgba(59, 130, 246, 0.48) 0%,
      rgba(37, 99, 235, 0.24) 36%,
      rgba(59, 130, 246, 0.08) 60%,
      transparent 72%);
    top: 50%; left: 50%;
    filter: blur(36px);
    animation: blobFloat1 18s ease-in-out infinite;
  }
  .hero-blob-2 {
    width: 480px; height: 420px;
    background: radial-gradient(ellipse at 50% 40%,
      rgba(96, 165, 250, 0.40) 0%,
      rgba(59, 130, 246, 0.18) 44%,
      transparent 68%);
    top: 44%; left: 54%;
    filter: blur(50px);
    animation: blobFloat2 24s ease-in-out infinite;
  }
  .hero-blob-3 {
    width: 320px; height: 280px;
    background: radial-gradient(ellipse at 50% 50%,
      rgba(59, 130, 246, 0.42) 0%,
      rgba(96, 165, 250, 0.18) 48%,
      transparent 70%);
    top: 56%; left: 46%;
    filter: blur(30px);
    animation: blobFloat3 11s ease-in-out infinite;
  }
  [data-theme="light"] .hero-blob-1 {
    background: radial-gradient(ellipse at 50% 44%,
      rgba(37, 99, 235, 0.26) 0%, rgba(59, 130, 246, 0.12) 40%, transparent 68%);
  }
  [data-theme="light"] .hero-blob-2 {
    background: radial-gradient(ellipse at 50% 40%,
      rgba(96, 165, 250, 0.20) 0%, rgba(37, 99, 235, 0.08) 48%, transparent 70%);
  }
  [data-theme="light"] .hero-blob-3 {
    background: radial-gradient(ellipse at 50% 50%,
      rgba(59, 130, 246, 0.18) 0%, rgba(96, 165, 250, 0.08) 48%, transparent 70%);
  }

  .hero-inner { position: relative; z-index: 1; max-width: 820px; }

  .hero-eyebrow {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent);
    margin-bottom: 1.75rem;
  }

  /* ── Hero title — slightly smaller, optically centered ── */
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(40px, 7.5vw, 96px);
    font-weight: 700; line-height: 1.18;
    letter-spacing: -0.03em; color: var(--fg);
    margin-bottom: 1.5rem;
  }
  .hero-title .word-in { display: block; }

  /* Optical centering: reduce trailing punctuation's visual weight */
  .hero-title .punct {
    font-size: 0.72em;
    letter-spacing: -0.42em; /* pulls in trailing space after 、/。 */
    vertical-align: 0.08em;
    opacity: 0.9;
  }

  .hero-en {
    font-family: var(--font-mono);
    font-size: clamp(13px, 2.2vw, 16px);
    letter-spacing: 0.06em; color: var(--fg-2);
    margin-bottom: 2.5rem;
    display: flex; flex-wrap: wrap; justify-content: center; gap: 0 0.4em;
  }
  .hero-en .t-en {
    font-family: var(--font-serif);
    font-size: clamp(14px, 2.5vw, 20px);
    letter-spacing: 0em; color: var(--fg-2);
  }

  .hero-sub {
    font-size: clamp(11px, 3vw, 14px); color: var(--fg-2); line-height: 1.9;
    margin-bottom: 3rem;
    max-width: 440px; margin-left: auto; margin-right: auto;
  }

  .hero-cta-row {
    display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute; bottom: 2rem; left: 0; right: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 7px;
    animation: scrollBounce 2.2s ease-in-out infinite; color: var(--fg-3);
  }
  .hero-scroll-line {
    width: 1px; height: 28px;
    background: linear-gradient(to bottom, transparent, var(--fg-3));
    flex-shrink: 0;
  }
  .hero-scroll-label {
    font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.6;
    display: block; text-align: center; padding-left: 0.2em;
  }
  .hero-scroll-arrow { display: block; }

  /* ━━ Sections ━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .section-wrap {
    max-width: 960px; margin: 0 auto; padding: 96px 3rem;
    border-top: 1px solid var(--border);
  }
  @media (max-width: 640px) { .section-wrap { padding: 64px 1.5rem; } }

  .section-header { margin-bottom: 3.5rem; }

  .section-num {
    font-family: var(--font-mono); font-size: 14px;
    letter-spacing: 0.1em; color: var(--accent);
    margin-bottom: 0.6rem; display: block;
  }

  /* Section title with ripple rings positioned on it */
  .section-title {
    font-family: var(--font-serif), var(--font-mono);
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700; letter-spacing: -0.02em; color: var(--fg); line-height: 1.1;
    position: relative; display: inline-block;
  }

  /* Ripple rings centered on the title text */
  .s-rip {
    position: absolute;
    left: 50%; top: 50%;
    width: 140px; height: 140px;
    border-radius: 50%;
    border: 1px solid var(--accent);
    opacity: 0; pointer-events: none;
    z-index: -1;
    animation: sRipple 4.5s ease-out infinite;
  }

  /* ━━ About ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;
  }
  @media (max-width: 700px) { .about-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

  .about-text { color: var(--fg); line-height: 2; }
  .about-text p { margin-top: 0; }
  .about-text p + p { margin-top: 1rem; }
  .about-text strong { color: #ffffff; font-weight: 400; }

  .about-cards { display: flex; flex-direction: column; gap: 1rem; }
  .about-card {
    padding: 1.1rem 1.25rem; border-radius: 10px;
    background: var(--bg-card); border: 1px solid var(--border);
  }
  .about-card-label {
    font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--fg-3); margin-bottom: 0.35rem;
  }
  .about-card-value { font-size: 13px; color: var(--fg); line-height: 1.6; }
  .about-card-value strong { color: var(--fg); font-weight: 600; }

  /* ━━ Services ━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
  }
  @media (max-width: 860px) { .services-grid { grid-template-columns: 1fr; } }

  .service-card {
    padding: 2rem 1.75rem 1.75rem; border-radius: 12px;
    background: var(--bg-card); border: 1px solid var(--border);
    position: relative; overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .service-card:hover {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.28);
  }
  .service-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent-bright));
    opacity: 0; transition: opacity 0.25s ease;
  }
  .service-card:hover::before { opacity: 1; }

  .service-num {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.1em; color: var(--accent); margin-bottom: 1.25rem; display: block;
  }
  .service-icon {
    width: 40px; height: 40px; border-radius: 10px; background: var(--accent-dim);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem; color: var(--accent);
  }
  .service-name {
    font-size: 16px; font-weight: 400; color: var(--fg); margin-bottom: 0.75rem; line-height: 1.4;
  }
  .service-desc {
    font-size: 13px; color: var(--fg-2); line-height: 1.85; margin-bottom: 1.5rem;
  }
  .service-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  /* ━━ Products ━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .products-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
  }
  @media (max-width: 640px) { .products-grid { grid-template-columns: 1fr; } }

  .product-card {
    border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border);
    padding: 2.5rem 2rem; text-align: center; position: relative; overflow: hidden;
    display: flex; flex-direction: column; align-items: center;
  }
  .product-card::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 50%, var(--accent-dim), transparent);
    pointer-events: none;
  }
  .product-card--app {
    text-decoration: none; transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .product-card--app:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    transform: translateY(-2px);
  }
  .product-app-icon {
    width: 72px; height: 72px; border-radius: 18px; margin-bottom: 1.25rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }
  .product-dots {
    display: flex; justify-content: center; gap: 8px; margin-bottom: 1.5rem;
  }
  .product-dots span {
    width: 8px; height: 8px; border-radius: 50%; background: var(--accent);
    animation: dotPulse 1.6s ease-in-out infinite;
  }
  .product-dots span:nth-child(2) { animation-delay: 0.2s; }
  .product-dots span:nth-child(3) { animation-delay: 0.4s; }

  .product-label {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem;
    width: 100%; text-align: center;
  }
  .product-title {
    font-size: 22px; color: var(--fg); margin-bottom: 0.6rem;
    font-family: var(--font-serif); font-weight: 700; letter-spacing: -0.02em;
    width: 100%; text-align: center;
  }
  .product-desc {
    font-size: 13px; color: var(--fg-2); line-height: 1.9; margin-bottom: 1.5rem;
    width: 100%; text-align: center;
  }
  .product-link {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em;
    color: var(--accent); display: inline-flex; align-items: center; gap: 0.3em;
    margin-top: auto;
  }
  .product-progress {
    max-width: 180px; margin: 0 auto; height: 2px;
    background: var(--border); border-radius: 9999px; overflow: hidden; position: relative;
    margin-top: auto;
  }
  .product-progress-bar {
    position: absolute; inset-y: 0; left: 0; width: 60px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--accent-bright), transparent);
    border-radius: 9999px; animation: shimmer 2s ease-in-out infinite;
  }

  /* ── Platforms ── */
  .platforms-wrap { margin-top: 3rem; }
  .platforms-heading {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--fg-3); margin-bottom: 1rem; display: block;
  }
  .platforms-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }
  @media (max-width: 500px) { .platforms-grid { grid-template-columns: 1fr; } }

  .platform-card {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    transition: border-color 0.2s ease;
  }
  .platform-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
  }
  .platform-icon {
    width: 38px; height: 38px; border-radius: 9px;
    background: var(--accent-dim);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); flex-shrink: 0;
  }
  .platform-name {
    font-family: var(--font-mono); font-size: 13px; color: var(--fg); letter-spacing: 0.02em;
  }
  .platform-os {
    font-family: var(--font-mono); font-size: 10px;
    color: var(--fg-3); letter-spacing: 0.06em; margin-top: 3px;
  }

  /* ━━ Contact ━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .contact-cards {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
  }
  @media (max-width: 700px) { .contact-cards { grid-template-columns: 1fr; } }

  .contact-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;
    padding: 1.75rem 1.5rem;
    display: flex; flex-direction: column; gap: 0;
  }
  a.contact-card {
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
  }
  a.contact-card:hover {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--border));
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.22);
  }
  .contact-card-icon {
    width: 38px; height: 38px; border-radius: 9px; background: var(--accent-dim);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); margin-bottom: 1.1rem;
  }
  .contact-card-label {
    font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--fg-3); margin-bottom: 0.4rem;
  }
  .contact-card-val {
    font-family: var(--font-mono); font-size: 13px; color: var(--accent);
    letter-spacing: 0.01em;
  }
  .contact-card-val.plain { color: var(--fg-2); font-family: var(--font-sans); font-size: 14px; }

  /* ━━ Footer ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  #footer {
    max-width: 960px; margin: 0 auto; padding: 2rem 3rem;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
    gap: 1rem; flex-wrap: wrap;
  }
  .footer-logo {
    font-family: var(--font-mono); font-size: 13px;
    display: inline-flex; align-items: center; gap: 7px;
  }
  .footer-logo-icon { flex-shrink: 0; border-radius: 4px; }
  .footer-logo-text {
    font-family: 'Space Grotesk', sans-serif; font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 50%, #3b82f6 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
    animation: logoFlow 7s ease-in-out infinite;
  }
  .footer-copy { font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); }
  .footer-legal a {
    font-family: var(--font-mono); font-size: 11px; color: var(--fg-3);
    transition: color 0.2s ease;
  }
  .footer-legal a:hover { color: var(--accent); }
  @media (max-width: 640px) {
    #footer { padding: 1.5rem; flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>

<!-- ── Navigation ── -->
<nav id="nav">
  <a href="/" class="nav-logo">
    <img src="/favicon.png" width="22" height="22" alt="" class="nav-logo-icon">
    <span class="nav-logo-text">RefineFlow Works</span>
  </a>

  <div class="nav-right">
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#services">Services</a></li>
      <li><a href="#products">Products</a></li>
      <li><a href="#platforms">Platforms</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
    <button id="lang-toggle" class="lang-toggle" aria-label="言語切り替え / Language">
      <span class="lt-ja">JP</span>
      <span class="lt-sep">/</span>
      <span class="lt-en">EN</span>
    </button>
    <button id="theme-toggle" class="theme-toggle" aria-label="ライト/ダークモード切り替え">
      <div class="theme-toggle-thumb">
        <svg id="toggle-icon-moon" class="theme-toggle-icon" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
        </svg>
        <svg id="toggle-icon-sun" class="theme-toggle-icon" style="display:none"
          viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/>
          <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/>
          <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
          <line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/>
          <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/>
          <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
        </svg>
      </div>
    </button>
  </div>
</nav>


<!-- ── Hero ── -->
<section id="hero">
  <div class="hero-blob hero-blob-1"></div>
  <div class="hero-blob hero-blob-2"></div>
  <div class="hero-blob hero-blob-3"></div>

  <div class="hero-inner">
    <p class="hero-eyebrow fade-in" style="animation-delay: 0.1s">App &amp; System Studio</p>

    <!--
      JP: 想いを、/ 動くものに。  (with optical punct adjustment)
      EN: Turning your vision / into reality.
    -->
    <h1 class="hero-title">
      <span class="word-in t-ja" style="animation-delay:0.35s">想いを<span class="punct">、</span></span>
      <span class="word-in t-ja" style="animation-delay:0.78s">動くものに<span class="punct">。</span></span>
      <span class="word-in t-en" style="animation-delay:0.35s">Turning your vision</span>
      <span class="word-in t-en" style="animation-delay:0.78s">into reality.</span>
    </h1>

    <!-- Subtitle (roles swap JP/EN) -->
    <p class="hero-en">
