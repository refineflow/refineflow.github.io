<script>
  // Nav scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 30);
  }, { passive: true });

  // Sync theme icon
  const moonIcon = document.getElementById('toggle-icon-moon') as HTMLElement | null;
  const sunIcon  = document.getElementById('toggle-icon-sun')  as HTMLElement | null;
  function syncThemeIcon() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (moonIcon) moonIcon.style.display = isDark ? 'block' : 'none';
    if (sunIcon)  sunIcon.style.display  = isDark ? 'none'  : 'block';
  }
  syncThemeIcon();
  document.getElementById('theme-toggle')?.addEventListener('click', () => setTimeout(syncThemeIcon, 0));
</script>
