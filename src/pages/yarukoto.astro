            <svg class="kmoon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.8 6.8 0 0 0 9.8 9.8z"/></svg>
          </span>
        </span>
      </button>
      <a class="appstore appstore--sm" href="#cta">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.05 12.04c-.03-2.6 2.12-3.85 2.22-3.91-1.21-1.77-3.09-2.01-3.76-2.04-1.6-.16-3.12.94-3.93.94-.81 0-2.06-.92-3.39-.89-1.74.03-3.35 1.01-4.25 2.57-1.81 3.14-.46 7.79 1.3 10.34.86 1.25 1.88 2.65 3.22 2.6 1.29-.05 1.78-.83 3.34-.83 1.55 0 2 .83 3.37.81 1.39-.03 2.27-1.27 3.12-2.53.98-1.45 1.39-2.85 1.41-2.93-.03-.01-2.7-1.04-2.73-4.13zM14.6 4.62c.71-.86 1.19-2.06 1.06-3.25-1.02.04-2.26.68-2.99 1.54-.66.76-1.23 1.98-1.08 3.15 1.14.09 2.3-.58 3.01-1.44z"/></svg>
        <span class="as-txt"><span class="as-big">App Store</span></span>
      </a>
      <a class="appstore appstore--sm appstore--alt" href="#cta">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.3 2.6a1 1 0 0 0-.5.9v17a1 1 0 0 0 .5.9l9.2-9.4L4.3 2.6zm10.3 8.1 2.9-3-9.1-5.2 6.2 8.2zm0 2.6-6.2 8.2 9.1-5.2-2.9-3zm1.4-1.3 2.9-1.7c.7-.4.7-1.4 0-1.8l-2.9-1.7L13.6 12l1.4 1z"/></svg>
        <span class="as-txt"><span class="as-big">Google Play</span></span>
      </a>
    </div>
  </div>
</nav>

<main id="top">

  <!-- ============ HERO ============ -->
