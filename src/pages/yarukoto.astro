              <svg class="device__sysicons" viewBox="0 0 84 24" fill="#fff" aria-hidden="true"><rect x="0" y="11" width="3.4" height="9" rx="1.1"/><rect x="6" y="8" width="3.4" height="12" rx="1.1"/><rect x="12" y="5" width="3.4" height="15" rx="1.1"/><rect x="18" y="2" width="3.4" height="18" rx="1.1"/><path d="M34 7.5c3.2-2.7 7.8-2.7 11 0M37 11c1.6-1.3 4.4-1.3 6 0" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"/><circle cx="40" cy="15" r="1.6"/><rect x="60" y="5" width="18" height="11" rx="3" fill="none" stroke="#fff" stroke-width="1.6"/><rect x="62" y="7.4" width="12" height="6.2" rx="1.4"/><rect x="79" y="8.4" width="2.4" height="4.2" rx="1.2"/></svg>
