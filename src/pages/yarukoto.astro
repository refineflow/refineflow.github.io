---
/*
  「やること」LP — Astro page  (refineflow.github.io 用)
  --------------------------------------------------------------
  設置:  このファイルを src/pages/yarukoto.astro に置く → /yarukoto で表示
          （サイト直下にしたいなら index.astro にリネーム）
  アセット:  public/yarukoto/ をリポジトリの public/yarukoto/ にコピー
          (icon/top/limit/edit/complete .png, styles.css, script.js)

  ・このページは自己完結型（独自の <head> を持つ）です。既存の Layout.astro や
    Tailwind の global.css には依存せず、干渉もしません。
  ・テーマは既存サイトと同じ localStorage キー "theme" を共有し、<html data-theme>
    を見て切り替わります。サイトのどこかでダーク/ライトを選ぶと、このLPにも反映されます。
  ・GitHub Pages のルート配信(base 未設定)に合わせ、パスは BASE_URL 経由で解決します。

  ※ 既存 Layout（共通ヘッダー/フォント/言語切替）に揃えたい場合は、<body> の中身を
     <Layout> でラップする「Layout統合版」も作れます（要相談）。
*/
const base = import.meta.env.BASE_URL;        // refineflow.github.io では "/"
const a = (f) => `${base}yarukoto/${f}`;
---
<!DOCTYPE html>
<html lang="ja" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>やること — シンプルなTODOアプリ｜RefineFlow Works</title>
<meta name="description" content="必要な機能だけを残した、心地よいTODOアプリ「やること」。やるべきことをシンプルに整理し、迷いを減らし、自然に次の一歩へ。日常の流れを整えます。">
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#0d1829" media="(prefers-color-scheme: dark)">
<meta property="og:title" content="やること — シンプルなTODOアプリ">
<meta property="og:description" content="必要な機能だけを残した、心地よいTODOアプリ。">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href={a('styles.css')} />
<script is:inline>
  // Set theme before first paint to avoid flash.
  (function () {
    try {
      var saved = localStorage.getItem('theme');
      var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    } catch (e) {}
  })();
</script>
</head>
<body>

<!-- ============ NAV ============ -->
<nav class="nav">
  <div class="wrap nav__inner">
    <a class="brand" href="#top" aria-label="やること ホーム">
      <img src={a('icon.png')} alt="">
      <span>やること</span>
    </a>
    <div class="nav__right">
      <button class="theme-switch" id="themeToggle" type="button" role="switch" aria-label="ライト・ダークモードを切り替える">
