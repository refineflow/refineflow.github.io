            </div>
            <div class="device__island"></div>
            <img src={a('edit.png')} alt="やること のタスク編集画面" decoding="async">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SECTION 2 — 整理 ============ -->
